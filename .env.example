PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/sarthiai
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Frontend (Next.js default dev port3001)
CORS_ORIGIN=http://localhost:3001
# Flag meals at/above this calorie count as "suspicious" in admin lists (default 5000)
SUSPICIOUS_MEAL_CALORIES_MIN=5000
# Behind a reverse proxy (nginx, etc.) — set so rate limits use X-Forwarded-For
TRUST_PROXY=false
